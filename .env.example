PORT=3000
NODE_ENV=development

# Email receiver (owner)
OWNER_EMAIL=owner@example.com

# SMTP transport (set your own provider credentials)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="LabX Contact <no-reply@example.com>"

# Optional Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Optional AI integration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Security / scalability
CORS_ORIGIN=*
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX=8

# Optional distributed rate-limit store
REDIS_URL=redis://localhost:6379
