{
  "name": "labx-developer-landing",
  "version": "1.0.0",
  "description": "Developer landing with API form and AI helper",
  "main": "dist/server/index.js",
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run build:client && tsx watch src/server/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "tsc -p tsconfig.client.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "lint": "eslint src tests e2e --ext .ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "npm run build:server && node --test dist/tests/**/*.test.js",
    "test:unit": "node --test dist/tests/validation.test.js",
    "test:integration": "node --test dist/tests/api.integration.test.js",
    "test:e2e": "playwright test",
    "test:all": "npm run build && npm run test && npm run test:e2e",
    "audit": "npm audit --audit-level=high",
    "build:docker": "docker build -t labx-developer-landing:local ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "nodemailer": "^6.9.14",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^4.3.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
